{
  "name": "aurelius",
  "version": "0.1.0",
  "description": "Open-source AI notetaker for macOS — fully local, no API keys",
  "main": "dist/main.js",
  "homepage": "./",
  "author": "Aurelius Contributors",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:electron\" \"npm run dev:react\"",
    "dev:react": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json && electron .",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "googleapis": "^128.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "socket.io-client": "^4.6.0",
    "zustand": "^4.4.0",
    "date-fns": "^3.0.0",
    "framer-motion": "^10.16.0",
    "lucide-react": "^0.294.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.aurelius.app",
    "productName": "Aurelius",
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"],
      "icon": "resources/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist"
    },
    "dmg": {
      "title": "Install Aurelius",
      "background": "resources/dmg-background.png",
      "window": { "width": 540, "height": 380 }
    },
    "files": ["dist/**/*", "resources/**/*"],
    "extraResources": [
      { "from": "../backend/dist/", "to": "backend/", "filter": ["**/*"] },
      { "from": "../resources/drivers/", "to": "drivers/", "filter": ["**/*"] },
      { "from": "../resources/models/", "to": "models/", "filter": ["**/*"] }
    ]
  }
}
