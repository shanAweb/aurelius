# Aurelius backend configuration — copy this file to `.env` and fill in values.
# `.env` is gitignored, so your secrets stay local.

# Google OAuth client (enables "Continue with Google" + calendar sync).
# Create an OAuth client ID of type "Desktop app" in Google Cloud Console,
# enable the Google Calendar API, then paste the credentials here.
AURELIUS_GOOGLE_CLIENT_ID=
AURELIUS_GOOGLE_CLIENT_SECRET=

# Optional overrides:
# AURELIUS_PORT=8765
# AURELIUS_DATA=~/.aurelius
